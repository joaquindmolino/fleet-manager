# Base de datos PostgreSQL
POSTGRES_USER=fleet
POSTGRES_PASSWORD=fleet_secret
POSTGRES_DB=fleet_manager

# Backend
DATABASE_URL=postgresql+asyncpg://fleet:fleet_secret@localhost:5432/fleet_manager
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change_me_in_production_use_openssl_rand_hex_32
ENVIRONMENT=development

# Firebase (notificaciones push)
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# SendGrid (email)
SENDGRID_API_KEY=
EMAIL_FROM=no-reply@fleetmanager.app
